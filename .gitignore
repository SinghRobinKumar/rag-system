# ══════════════════════════════════════════════════════════════
# RAG System — .gitignore
# ══════════════════════════════════════════════════════════════

# ─── Python ──────────────────────────────────────────────────
venv/
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# ─── ChromaDB / Vector Store ────────────────────────────────
chroma_db/

# ─── User Data (documents uploaded by users) ────────────────
# Keep directory structure but not actual files
data/**/*
!data/.gitkeep
!data/clients/.gitkeep
!data/vendors/.gitkeep
!data/customers/.gitkeep

# ─── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Environment / Secrets ──────────────────────────────────
.env
.env.local
*.env

# ─── OS ──────────────────────────────────────────────────────
*.log
*.pid
*.seed

# ─── Misc ────────────────────────────────────────────────────
.gemini/
node_modules/
